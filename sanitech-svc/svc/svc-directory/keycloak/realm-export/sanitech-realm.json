      {
        "name": "DOCTOR"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "realmRoles": [
        "ADMIN"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ]
    },
    {
      "username": "doctor",
      "enabled": true,
      "realmRoles": [
        "DOCTOR"
      ],
      "attributes": {
        "dept": [
          "CARDIO"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "doctor",
          "temporary": false
        }
      ]
    }
  ]
