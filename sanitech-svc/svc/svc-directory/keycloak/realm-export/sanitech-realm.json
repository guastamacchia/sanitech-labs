{
  "realm": "sanitech",
  "enabled": true,
  "displayName": "Sanitech",
  "clients": [
    {
      "clientId": "svc-directory",
      "name": "svc-directory",
      "secret": "svc-directory-secret",
      "protocol": "openid-connect",
