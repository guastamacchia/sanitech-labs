root = true

############################
# DEFAULT (tutti i file)
############################

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

############################
# JAVA
############################

[*.java]
indent_size = 4

############################
# XML (Maven, Spring, ecc.)
############################

[*.xml]
indent_size = 4

############################
# YAML
############################

[*.yml]
indent_size = 2

[*.yaml]
indent_size = 2

############################
# MARKDOWN
############################

[*.md]
trim_trailing_whitespace = false
