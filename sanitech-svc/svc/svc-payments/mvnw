#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper script (standard).
# Se manca .mvn/wrapper/maven-wrapper.jar, rigeneralo con:
#   mvn -N io.takari:maven:wrapper
# ----------------------------------------------------------------------------

BASEDIR=$(cd "$(dirname "$0")"; pwd -P)

MAVEN_PROJECTBASEDIR="$BASEDIR"
export MAVEN_PROJECTBASEDIR

if [ -f "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" ]; then
  JAVA_EXEC="${JAVA_HOME:-}/bin/java"
  if [ ! -x "$JAVA_EXEC" ]; then
    JAVA_EXEC="java"
  fi

  exec "$JAVA_EXEC" -jar "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" "$@"
else
  echo "maven-wrapper.jar non trovato. Usa 'mvn ...' oppure rigenera il wrapper con:"
  echo "  mvn -N io.takari:maven:wrapper"
  exec mvn "$@"
fi
