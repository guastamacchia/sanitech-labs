############################################
# Spring
############################################
SPRING_PROFILES_ACTIVE=default

############################################
# Database (PostgreSQL)
############################################
DATABASE_NAME=sanitech_gateway
DATABASE_USER=sanitech
DATABASE_PASSWORD=sanitech
DB_URL=jdbc:postgresql://postgres:5432/sanitech_gateway

############################################
# Kafka (KRaft – single node)
############################################
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_ADVERTISED_HOST=10.211.55.23
CLUSTER_ID=FJj8tJxkQp2y7Qm3u1kGxA

KAFKA_PRODUCER_RETRIES=10
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_LINGER_MS=5

############################################
# Keycloak (bootstrap staging)
############################################
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KC_HEALTH_ENABLED=true

############################################
# OAuth2 / OIDC
############################################
OAUTH2_ISSUER_URI=http://keycloak:8080/realms/sanitech

############################################
# CORS
############################################
CORS_ALLOWED_ORIGINS=http://10.211.55.23:3000

############################################
# Grafana / osservabilità
############################################
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

############################################
# SERVICE – ACCESSO ESTERNO (host remoto)
############################################
SERVICE_URL=http://10.211.55.23:8080
KEYCLOAK_URL=http://10.211.55.23:8081
PROMETHEUS_URL=http://10.211.55.23:9090
GRAFANA_URL=http://10.211.55.23:3000

############################################
# Downstream services (staging host)
############################################
DIRECTORY_URL=http://10.211.55.23:8082
SCHEDULING_URL=http://10.211.55.23:8083
ADMISSIONS_URL=http://10.211.55.23:8084
CONSENTS_URL=http://10.211.55.23:8085
DOCS_URL=http://10.211.55.23:8086
NOTIFICATIONS_URL=http://10.211.55.23:8087
AUDIT_URL=http://10.211.55.23:8088
TELEVISIT_URL=http://10.211.55.23:8089
PAYMENTS_URL=http://10.211.55.23:8090
PRESCRIBING_URL=http://10.211.55.23:8091

