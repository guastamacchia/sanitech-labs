############################################
# Spring
############################################
SPRING_PROFILES_ACTIVE=default

############################################
# OIDC
############################################
OAUTH2_ISSUER_URI=http://host.docker.internal:8081/realms/sanitech

############################################
# Downstream services (remote host access)
############################################
DIRECTORY_URL=http://host.docker.internal:8082
SCHEDULING_URL=http://host.docker.internal:8083
ADMISSIONS_URL=http://host.docker.internal:8084
CONSENTS_URL=http://host.docker.internal:8085
DOCS_URL=http://host.docker.internal:8086
NOTIFICATIONS_URL=http://host.docker.internal:8087
AUDIT_URL=http://host.docker.internal:8088
TELEVISIT_URL=http://host.docker.internal:8089
PAYMENTS_URL=http://host.docker.internal:8090
PRESCRIBING_URL=http://host.docker.internal:8091

############################################
# OpenAPI endpoints (remote host access)
############################################
OPENAPI_DIRECTORY_URL=http://host.docker.internal:8082/v3/api-docs/directory
OPENAPI_SCHEDULING_URL=http://host.docker.internal:8083/v3/api-docs/scheduling
OPENAPI_ADMISSIONS_URL=http://host.docker.internal:8084/v3/api-docs/admissions
OPENAPI_CONSENTS_URL=http://host.docker.internal:8085/v3/api-docs/consents
OPENAPI_DOCS_URL=http://host.docker.internal:8086/v3/api-docs/docs
OPENAPI_NOTIFICATIONS_URL=http://host.docker.internal:8087/v3/api-docs/notifications
OPENAPI_AUDIT_URL=http://host.docker.internal:8088/v3/api-docs/audit
OPENAPI_TELEVISIT_URL=http://host.docker.internal:8089/v3/api-docs/televisit
OPENAPI_PAYMENTS_URL=http://host.docker.internal:8090/v3/api-docs/payments
OPENAPI_PRESCRIBING_URL=http://host.docker.internal:8091/v3/api-docs/prescribing
