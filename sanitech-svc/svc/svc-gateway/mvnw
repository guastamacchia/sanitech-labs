#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Wrapper startup script, version 3.3.2
# (https://github.com/takari/maven-wrapper)
# ----------------------------------------------------------------------------

# Required for POSIX compliance
set -e

MVNW_REPOURL="https://repo.maven.apache.org/maven2"
MVNW_VERBOSE="${MVNW_VERBOSE:-false}"

# Resolve the location of the script
PRG="$0"
while [ -h "$PRG" ]; do
  ls=`ls -ld "$PRG"`
  link=`expr "$ls" : '.*-> \(.*\)$'`
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=`dirname "$PRG"`"/$link"
  fi
done

SAVEDIR=`pwd`
BASEDIR=`dirname "$PRG"`
BASEDIR=`cd "$BASEDIR" && pwd`
cd "$SAVEDIR"

WRAPPER_DIR="$BASEDIR/.mvn/wrapper"
JAR="$WRAPPER_DIR/maven-wrapper.jar"
PROPERTIES="$WRAPPER_DIR/maven-wrapper.properties"

# Download maven-wrapper.jar if needed
if [ ! -f "$JAR" ]; then
  if [ "$MVNW_VERBOSE" = "true" ]; then
    echo "Downloading $JAR"
  fi

  if [ ! -f "$PROPERTIES" ]; then
    echo "Missing $PROPERTIES"
    exit 1
  fi

  WRAPPER_URL=`grep -E '^wrapperUrl=' "$PROPERTIES" | cut -d'=' -f2-`
  if [ -z "$WRAPPER_URL" ]; then
    WRAPPER_URL="$MVNW_REPOURL/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  fi

  mkdir -p "$WRAPPER_DIR"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$WRAPPER_URL" -o "$JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$WRAPPER_URL" -O "$JAR"
  else
    echo "To use the Maven Wrapper, please install curl or wget."
    exit 1
  fi
fi

JAVA_EXEC="${JAVA_HOME:-}/bin/java"
if [ ! -x "$JAVA_EXEC" ]; then
  JAVA_EXEC="java"
fi

exec "$JAVA_EXEC" -jar "$JAR" "$@"
