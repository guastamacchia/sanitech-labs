#!/bin/sh
# Maven Wrapper - minimal script (generated)
# Runs Maven using the wrapper JAR downloaded automatically if missing.

BASE_DIR="$(cd "$(dirname "$0")" && pwd)"

WRAPPER_JAR="$BASE_DIR/.mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES="$BASE_DIR/.mvn/wrapper/maven-wrapper.properties"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "maven-wrapper.jar not found, downloading..."
  MAVEN_WRAPPER_URL="https://repo.maven.apache.org/maven2/org/apache/maven/wrapper/maven-wrapper/3.3.2/maven-wrapper-3.3.2.jar"
  mkdir -p "$(dirname "$WRAPPER_JAR")"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_WRAPPER_URL" -o "$WRAPPER_JAR"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$MAVEN_WRAPPER_URL" -O "$WRAPPER_JAR"
  else
    echo "ERROR: curl or wget required to download maven-wrapper.jar"
    exit 1
  fi
fi

exec java -jar "$WRAPPER_JAR" "$@"
